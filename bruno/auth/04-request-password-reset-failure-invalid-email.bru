meta {
  name: Request password reset with invalid email
  type: http
  seq: 4
}

post {
  url: {{host}}/api/auth/password-reset
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body {
  {
    "email": "{{invalidEmail}}"
  }
}

tests {
  test("should return 400", function() {
    expect(res.status).to.equal(400);
  });
}
