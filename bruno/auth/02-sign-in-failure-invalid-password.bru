meta {
  name: Sign in customer with invalid password
  type: http
  seq: 2
}

post {
  url: {{host}}/api/auth/sign-in
  body: json
  auth: none
}

headers {
  content-type: application/json
}

body {
  {
    "email": "{{email}}",
    "password": "WrongPassword123!"
  }
}

tests {
  test("should return 401", function() {
    expect(res.status).to.equal(401);
  });
}
